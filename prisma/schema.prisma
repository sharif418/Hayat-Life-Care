generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
  type  String @default("text") // text, json, image
  group String @default("general")
  label String?
  updatedAt DateTime @updatedAt
}

model Service {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  icon        String?
  image       String?
  floor       String?
  category    String?
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Doctor {
  id          String   @id @default(cuid())
  name        String
  specialty   String
  designation String?
  image       String?
  chamber     String?
  floor       String?
  schedule    String?
  bio         String?
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Leader {
  id          String   @id @default(cuid())
  name        String
  designation String
  bio         String
  image       String?
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String   @default("general")
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Inquiry {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String
  subject   String?
  message   String
  status    String   @default("new") // new, read, replied
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  role      String   // user, assistant
  content   String
  createdAt DateTime @default(now())
}

model Video {
  id          String   @id @default(cuid())
  title       String
  description String
  youtubeId   String
  thumbnail   String?
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DownloadLead {
  id        String   @id @default(cuid())
  name      String
  phone     String
  source    String   @default("brochure") // which download triggered this
  createdAt DateTime @default(now())
}

model DownloadEvent {
  id        String   @id @default(cuid())
  type      String   @default("brochure") // what was downloaded
  hasLead   Boolean  @default(false) // did user provide info or skip?
  leadId    String?  // reference to DownloadLead if provided
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
}

model SiteVisit {
  id          String   @id @default(cuid())
  visitorId   String   // fingerprint/cookie-based unique visitor
  page        String   @default("/")
  referrer    String?
  ip          String?
  userAgent   String?
  isUnique    Boolean  @default(false) // first visit from this visitorId today
  createdAt   DateTime @default(now())
}

model Testimonial {
  id          String   @id @default(cuid())
  name        String
  designation String
  text        String
  photo       String?  // base64 or URL
  rating      Int      @default(5) // 1-5 stars
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
